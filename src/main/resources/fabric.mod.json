{
  "schemaVersion": 1,
  "id": "trade-reorder",
  "version": "${version}",
  "name": "Trade Reorder",
  "description": "Adds villager trade reordering and a singleplayer view of generated future villager trades.",
  "authors": [ "You" ],
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.example.tradereorder.TradeReorder"
    ],
    "client": [
      "com.example.tradereorder.TradeReorderClient"
    ]
  },
  "mixins": [
    "trade-reorder.mixins.json",
    {
      "config": "trade-reorder.client.mixins.json",
      "environment": "client"
    }
  ],
  "classTweaker": "trade-reorder.classtweaker",
  "depends": {
    "fabricloader": ">=0.18.4",
    "minecraft": "~26.1.2",
    "java": ">=25",
    "fabric-api": "*"
  }
}
